APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# 신규 기관 등록(/institutions/create): true 시 등록 페이지·저장 허용
INSTITUTION_CREATE_ENABLED=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=
# 그누보드(상품 마스터) 보조 연결 - 읽기 전용 권장
# DB_GRAPESEED_GOODS_HOST=127.0.0.1
# DB_GRAPESEED_GOODS_PORT=3307
# DB_GRAPESEED_GOODS_DATABASE=grapeseedgoods2
# DB_GRAPESEED_GOODS_USERNAME=root
# DB_GRAPESEED_GOODS_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# 로컬은 log 드라이버로 메일 본문이 storage/logs에 쌓입니다. 운영·스테이징에서는 smtp 등으로 바꾸세요.
# 신규 직원 «로그인 계정 발급» 시 비밀번호 재설정 링크 메일이 이 설정으로 발송됩니다.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

STORE_DATA_SOURCE=ecount
STORE_SALES_HISTORY_SOURCE=ecount
# 그누보드 상품마스터(g5_shop_item)에서 보조 컬럼(알림수량)을 읽어옵니다.
STORE_GNUBOARD_ENABLED=true
STORE_GNUBOARD_CONNECTION=mysql_grapeseed_goods
STORE_GNUBOARD_ITEM_TABLE=g5_shop_item
STORE_GNUBOARD_PRODUCT_CODE_COLUMN=it_model
STORE_GNUBOARD_FALLBACK_PRODUCT_CODE_COLUMN=it_id
STORE_GNUBOARD_ITEM_NAME_COLUMN=it_name
STORE_GNUBOARD_NOTIFY_QTY_COLUMN=it_noti_qty
STORE_GNUBOARD_STOCK_QTY_COLUMN=it_stock_qty
# 판매내역을 그누보드 주문 테이블로 조회할 때 사용할 기본 매핑 (읽기 전용 SELECT)
STORE_GNUBOARD_ORDER_TABLE=g5_shop_order
STORE_GNUBOARD_CART_TABLE=g5_shop_cart
STORE_GNUBOARD_ORDER_ID_COLUMN=od_id
STORE_GNUBOARD_ORDER_DATETIME_COLUMN=od_time
STORE_GNUBOARD_ORDER_STATUS_COLUMN=od_status
STORE_GNUBOARD_CART_PRODUCT_ID_COLUMN=it_id
STORE_GNUBOARD_CART_QTY_COLUMN=ct_qty
STORE_GNUBOARD_CART_NAME_COLUMN=it_name
STORE_GNUBOARD_CART_STATUS_COLUMN=ct_status
STORE_GNUBOARD_ORDER_SETTLE_CASE_COLUMN=od_settle_case
STORE_GNUBOARD_ORDER_CUSTOMER_NAME_COLUMN=od_name
STORE_GNUBOARD_EXCLUDED_ORDER_STATUSES=취소,주문취소
STORE_GNUBOARD_EXCLUDED_CART_STATUSES=취소
STORE_GNUBOARD_SALES_LOOKBACK_DAYS=180
STORE_GNUBOARD_SALES_MAX_HISTORIES=5
STORE_GNUBOARD_SALES_MAX_ROWS_PER_QUERY=5000
# --- 이카운트 세션 자동 발급(OAPILogin) ---
# ECOUNT_SESSION_ID를 비우고 아래를 채우면 앱이 로그인 API로 세션을 받아 캐시합니다.
# ECOUNT_COM_CODE=회사코드  ECOUNT_USER_ID=사용자ID  ECOUNT_API_CERT_KEY=포털에서 발급한 OAPI 인증키
# ECOUNT_AUTO_LOGIN_WHEN_EMPTY_SESSION=true (기본값) 유지
# 첫 연결 시 ECOUNT_ZONE이 비어 있으면 Zone API로 ZONE을 조회합니다. {ZONE} URL을 쓰는 경우
#   ECOUNT_ZONE을 미리 넣거나, 한 번 성공한 뒤 응답 ZONE이 캐시되어 이후 호출에 사용됩니다.
# 수동 확인: php artisan ecount:session   강제 재발급: php artisan ecount:session --refresh
# --- 호스트·세션(수동으로 SESSION_ID를 넣을 때는 위 자동 발급 변수는 생략 가능) ---
# ZONE은 호스트에 붙는 값입니다. 예: ZONE=BB → https://oapiBB.ecount.com (운영) / https://sboapiBB.ecount.com (테스트)
# 잘못된 예: https://oapi.BB.ecount.com (DNS 없음)
# 세션을 어디서 발급받았는지(oapi vs sboapi)와 반드시 동일한 호스트로 호출할 것
ECOUNT_API_BASE_URL=https://oapi{ZONE}.ecount.com
# Zone API 전용 호스트(ECOUNT_ZONE이 비어 있을 때). {ZONE}만 있는 URL로는 Zone 조회가 불가능해 기본값 사용
ECOUNT_ZONE_LOOKUP_BASE_URL=https://oapi.ecount.com
ECOUNT_ZONE=
ECOUNT_SESSION_ID=
ECOUNT_API_INVENTORY_ENDPOINT=/OAPI/V2/InventoryBalance/GetListInventoryBalanceStatus
# 재고현황만으로는 품목명이 없을 수 있어, 품목 기본 조회로 PROD_DES를 합침 (false 로 끄기 가능)
ECOUNT_FETCH_PRODUCT_NAMES=true
ECOUNT_API_PRODUCT_BASIC_ENDPOINT=/OAPI/V2/InventoryBasic/GetBasicProductsList
ECOUNT_PRODUCT_BASIC_CHUNK_SIZE=20
# 최근 차감 이력 조회 API (둘 다 비우면 차감 정보 표시 비활성). 둘 다 지정 시 품목별로 더 최근 시각만 표시
# 수불 이력 예: /OAPI/V2/InventoryBalance/GetListInventoryMovementHistory
ECOUNT_API_MOVEMENT_ENDPOINT=
# 판매 목록 예(테스트 호스트): https://sboapi{ZONE}.ecount.com/OAPI/V2/Sale/GetListSale?SESSION_ID=...
ECOUNT_API_SALE_LIST_ENDPOINT=
# GetListSale 요청 JSON에 COM_CODE 포함 (일부 환경에서 필수. 오류 시 false)
ECOUNT_SALE_LIST_INCLUDE_COM_CODE=true
ECOUNT_FETCH_DEDUCT_LOGS=true
ECOUNT_MOVEMENT_CHUNK_SIZE=20
ECOUNT_MOVEMENT_LOOKBACK_DAYS=90
ECOUNT_WAREHOUSE_CODE=
ECOUNT_BASE_DATE=
# 이카운트 품목코드(PROD_CD). 여러 개는 쉼표로: 00P228,00P227 (앱에서 이카운트 구분자로 변환)
# 비우면 전체 조회. 한 번에 최대 20개까지(ECOUNT_INVENTORY_MAX_PROD_CD)
ECOUNT_PRODUCT_CODE=
ECOUNT_INVENTORY_MAX_PROD_CD=20
ECOUNT_CACHE_TTL_SECONDS=120
ECOUNT_CACHE_PREFIX=store_inventory
ECOUNT_SESSION_REFRESH_ENABLED=false
# ECOUNT_SESSION_ID가 비어 있을 때 OAPILogin으로 세션 자동 발급 (COM_CODE/USER_ID/API_CERT_KEY 필요)
ECOUNT_AUTO_LOGIN_WHEN_EMPTY_SESSION=true
ECOUNT_API_ZONE_ENDPOINT=/OAPI/V2/Zone
ECOUNT_API_LOGIN_ENDPOINT=/OAPI/V2/OAPILogin
ECOUNT_COM_CODE=
ECOUNT_USER_ID=
ECOUNT_API_CERT_KEY=
ECOUNT_LAN_TYPE=ko-KR
ECOUNT_ZERO_FLAG=N
ECOUNT_BAL_FLAG=N
ECOUNT_DEL_GUBUN=N
ECOUNT_SAFE_FLAG=N
STORE_API_TIMEOUT=10
